font-family = JetBrainsMono Nerd Font
font-size = 14
command = /usr/bin/zsh
background-opacity = 0.91
background-blur=true
# theme is managed by ~/.local/bin/theme-apply (rose-pine | gruvbox)
theme = Kanagawa Dragon

# Copy/paste (latin + russian layout)
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+с=copy_to_clipboard
keybind = ctrl+shift+м=paste_from_clipboard
